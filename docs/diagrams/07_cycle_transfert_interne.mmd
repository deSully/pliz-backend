flowchart TD
    A(["Requête POST\n/api/transaction/wallet/topup/"]) --> B["Validation JWT + KYC level"]
    B --> C["INSERT Transaction\nstatus = PENDING\nexternal_reference = null"]
    C --> D["Appel API Partenaire\nDjamo · SamirPay · MTN"]
    D --> E["Stockage external_reference\n+ INSERT TransactionStatusCheck"]
    E --> F(["Réponse immédiate 202\norder_id retourné au client"])

    G(["Webhook entrant\nPOST /api/transaction/webhooks/partner/"]) --> H["Vérification\nHMAC-SHA256"]
    H --> I{"Signature\nvalide ?"}
    I -- Non --> J(["Rejet 401 — loggé"])
    I -- Oui --> K{"Déjà traité ?\nexternal_reference UNIQUE"}
    K -- Oui --> L(["200 ACK — idempotent"])
    K -- Non --> M["CREDIT wallet utilisateur\n+ INSERT WalletBalanceHistory"]
    M --> N["UPDATE Transaction\nstatus = SUCCESS"]
    N --> O["FCM push notify\nstatus temps réel"]
    O --> L
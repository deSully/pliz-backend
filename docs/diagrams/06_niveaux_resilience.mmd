flowchart TD
    A(["Requête POST\n/api/transaction/send-money/"]) --> B["Validation JWT\n+ Rate limit check"]
    B --> C["Résolution destinataire\nUUID ou numéro de téléphone"]
    C --> D{"Solde\nsuffisant ?"}
    D -- Non --> E(["Rejet 400\nINSUFFICIENT_FUNDS\nloggé"])
    D -- Oui --> F["BEGIN TRANSACTION\nSERIALIZABLE"]
    F --> G["INSERT Transaction\nstatus = PENDING"]
    G --> H["DEBIT wallet expéditeur\n+ INSERT WalletBalanceHistory"]
    H --> I["CREDIT wallet destinataire\n+ INSERT WalletBalanceHistory"]
    I --> J["Débit frais → wallet PLIIIZ\n+ INSERT FeeDistribution"]
    J --> K["UPDATE Transaction\nstatus = SUCCESS"]
    K --> L["COMMIT"]
    L --> M["FCM push notify\nexpéditeur + destinataire"]
    M --> N(["Réponse 200 OK\norder_id + status: success"])
